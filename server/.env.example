# anima-web server configuration
# Copy this file to .env and modify as needed:  cp .env.example .env

# ─── Server ───────────────────────────────────────────────
# ANIMA_HOST=0.0.0.0
# ANIMA_PORT=19000

# ─── Remote API ───────────────────────────────────────────
# ANIMA_API_BASE_URL=https://sumi.sumeruai.com
# ANIMA_WS_URL=

# ─── OpenClaw ─────────────────────────────────────────────
# Scenario 1: OpenClaw deployed locally (same machine)
#   OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions
#
# Scenario 2: OpenClaw on remote server, Gateway binds 0.0.0.0
#   OPENCLAW_API_URL=http://<remote-ip>:18789/v1/chat/completions
#
# Scenario 3: OpenClaw on remote server, Gateway binds 127.0.0.1 (default)
#   First create SSH tunnel:  ssh -L 18789:127.0.0.1:18789 user@<remote-ip>
#   Then use localhost:
#   OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions
#
OPENCLAW_API_URL=http://127.0.0.1:18789/v1/chat/completions
OPENCLAW_TOKEN=your-openclaw-token-here
OPENCLAW_DEFAULT_AGENT=main

# ─── OpenClaw Agent Management (SSH) ────────────────────
# Required for remote agent creation/management from the frontend.
# Leave empty if OpenClaw is installed locally.
# Requires SSH key-based auth (ssh-copy-id user@host).
# OPENCLAW_SSH_HOST=agent@10.10.5.24
# OPENCLAW_WORKSPACE_BASE=/home/agent/.openclaw
